{
  "appId": "com.cyber.targetsync",
  "appName": "SyncAgent",
  "webDir": "www",
  "bundledWebRuntime": false,
  "plugins": {
    "SMSReader": {
      "androidPermissions": [
        "android.permission.READ_SMS",
        "android.permission.RECEIVE_SMS"
      ]
    },
    "CallLog": {
      "androidPermissions": [
        "android.permission.READ_CALL_LOG"
      ]
    }
  }
}
